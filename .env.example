# Copy to .env and fill in. All VITE_* vars are exposed to the client.

# Sui GraphQL endpoint. If unset, uses "/testnet-graphql" (relative — needs proxy or same host).
# VITE_SUI_GRAPHQL_ENDPOINT=

# EVE Frontier world package ID on Sui (used to filter owned objects).
VITE_EVE_WORLD_PACKAGE_ID=

# Cloudflare Worker URL (snapshot + history API).
# Leave empty in dev — vite proxy forwards /api → http://127.0.0.1:3001
# In production set this to your deployed Worker URL, e.g.:
#   VITE_WORKER_URL=https://jotunn-snapshot.your-account.workers.dev
VITE_WORKER_URL=

# Spotify (optional). Public playlist embed works without key.
# VITE_SPOTIFY_PLAYLIST_ID=37i9dQZF1DWWvvyNmFQkx5
# VITE_SPOTIFY_API_KEY=
